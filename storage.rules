rules_version = '2';
service firebase.storage {
  // Broadly match the standard bucket
  match /b/mailplus-outbound-leads-crm.appspot.com/o {
    match /{allPaths=**} {
      allow read, write: if true;
    }
  }
  // Broadly match the new storage bucket
  match /b/mailplus-outbound-leads-crm.firebasestorage.app/o {
    match /{allPaths=**} {
      allow read, write: if true;
    }
  }
  // Fallback for any other internal bucket names
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read, write: if true;
    }
  }
}
