rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Users can only read and write their own data.
    match /users/{userId} {
      allow read, update: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null;
      
      // Allow access to user routes
      match /routes/{routeId} {
        allow read, write: if request.auth != null && (request.auth.uid == userId || resource.data.isUnassigned == true);
      }
    }

    // Collection group rule for routes
    match /{path=**}/routes/{routeId} {
      allow read: if request.auth != null && (request.auth.uid == resource.data.userId || resource.data.isUnassigned == true);
      allow update: if request.auth != null && (request.auth.uid == resource.data.userId || resource.data.isUnassigned == true);
    }

    // Leads and their subcollections
    match /leads/{leadId}/{document=**} {
      allow read, write: if request.auth != null;
    }

    // Companies and their subcollections
    match /companies/{companyId}/{document=**} {
      allow read, write: if request.auth != null;
    }

    // Visit Notes
    match /visitnotes/{noteId} {
      allow create: if request.auth != null;
      allow read, update, delete: if request.auth != null && (
        request.auth.uid == resource.data.capturedByUid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'Lead Gen Admin', 'Field Sales Admin']
      );
    }
  }
}