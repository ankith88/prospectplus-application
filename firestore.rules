
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.disabled != true;
    }
    
    function isAdmin() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    function isFieldSalesAdmin() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Field Sales Admin';
    }

    // Services collection
    match /services/{serviceId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      
      match /routes/{routeId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated() && (request.auth.uid == userId || isAdmin() || isFieldSalesAdmin());
      }
    }

    // Collection group rules for global reporting and history
    match /{path=**}/routes/{routeId} {
      allow read: if isAuthenticated();
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin() || isFieldSalesAdmin());
    }
    
    match /{path=**}/activity/{activityId} {
      allow read: if isAuthenticated();
    }
    
    match /{path=**}/appointments/{appointmentId} {
      allow read: if isAuthenticated();
    }
    
    match /{path=**}/notes/{noteId} {
      allow read: if isAuthenticated();
    }
    
    match /{path=**}/transcripts/{transcriptId} {
      allow read: if isAuthenticated();
    }
    
    match /{path=**}/scorecards/{scorecardId} {
      allow read: if isAuthenticated();
    }
    
    match /{path=**}/tasks/{taskId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Franchisees metadata records
    match /franchisees/{franchiseeId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (
        // Key Constraints
        franchiseeId == request.resource.data.internalId &&
        
        // Data Schema Rules
        request.resource.data.internalId is string &&
        request.resource.data.name is string &&
        request.resource.data.mainContact is string &&
        request.resource.data.email is string &&
        request.resource.data.email.matches('.*@mailplus\\.com\\.au$') &&
        request.resource.data.mobile is string &&
        request.resource.data.isCompanyOwned is bool &&
        request.resource.data.commissionRate is number &&
        request.resource.data.salesRepAssigned is string &&
        request.resource.data.activeProjects is list &&
        request.resource.data.mpExpressActivated is bool &&
        request.resource.data.territoryRaw is string &&
        request.resource.data.territoryJson is list &&
        request.resource.data.mpStarTrackActivated is bool &&
        request.resource.data.starTrackSuburbRaw is string &&
        request.resource.data.starTrackSuburbsJson is list &&
        request.resource.data.ausPostSuburbsRaw is string &&
        request.resource.data.ausPostSuburbsJson is list
      );
    }

    // Leads and their subcollections
    match /leads/{leadId}/{document=**} {
      allow read, write: if isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role != 'Franchisee' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.franchisee == (
          exists(/databases/$(database)/documents/leads/$(leadId)) ? 
          get(/databases/$(database)/documents/leads/$(leadId)).data.franchisee : 
          null
        )
      );
    }

    // Companies and their subcollections
    match /companies/{companyId}/{document=**} {
      allow read, write: if isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role != 'Franchisee' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.franchisee == (
          exists(/databases/$(database)/documents/companies/$(companyId)) ? 
          get(/databases/$(database)/documents/companies/$(companyId)).data.franchisee : 
          null
        )
      );
    }

    // Visit Notes
    match /visitnotes/{noteId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAuthenticated() && (
        request.auth.uid == resource.data.capturedByUid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'Lead Gen Admin', 'Field Sales Admin'] ||
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Franchisee' && resource.data.franchisee == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.franchisee)
      );
    }

    // Upsells
    match /upsells/{upsellId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
    }

    // Daily Deployment Logs
    match /daily_area_logs/{logId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
    }

    // Team Schedules
    match /field_sales_schedules/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isFieldSalesAdmin();
    }

    // Marketing Campaigns collections
    match /marketing_templates/{templateId} {
      allow read, create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'Marketing Admin', 'Marketing Manager'] ||
        (exists(resource.data.createdBy) && resource.data.createdBy == request.auth.uid) ||
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Sales Manager' && 
         exists(resource.data.createdByRole) && 
         resource.data.createdByRole in ['Account Managers', 'Account Manager', 'account managers'])
      );
    }
    match /marketing_sms_templates/{templateId} {
      allow read, create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'Marketing Admin', 'Marketing Manager'] ||
        (exists(resource.data.createdBy) && resource.data.createdBy == request.auth.uid) ||
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Sales Manager' && 
         exists(resource.data.createdByRole) && 
         resource.data.createdByRole in ['Account Managers', 'Account Manager', 'account managers'])
      );
    }
    match /marketing_campaigns/{campaignId} {
      allow read, write: if isAuthenticated();
    }
    match /campaign_deliveries/{deliveryId} {
      allow read, write: if isAuthenticated();
    }
    match /marketing_suppression_list/{email} {
      allow read, write: if isAuthenticated();
    }
    match /outlook_integrations/{configId} {
      allow read, write: if isAuthenticated();
    }
    match /journeys/{journeyId} {
      allow read, write: if isAuthenticated();
    }
    match /Journeys/{journeyId} {
      allow read, write: if isAuthenticated();
    }
  }
}
