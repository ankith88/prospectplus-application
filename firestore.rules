
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    function isFieldSalesAdmin() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Field Sales Admin';
    }

    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      
      match /routes/{routeId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated() && (request.auth.uid == userId || isAdmin() || isFieldSalesAdmin());
      }
    }

    // Collection group rules for global reporting and history
    match /{path=**}/routes/{routeId} {
      allow read: if isAuthenticated();
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin() || isFieldSalesAdmin());
    }
    
    match /{path=**}/activity/{activityId} {
      allow read: if isAuthenticated();
    }
    
    match /{path=**}/appointments/{appointmentId} {
      allow read: if isAuthenticated();
    }
    
    match /{path=**}/notes/{noteId} {
      allow read: if isAuthenticated();
    }
    
    match /{path=**}/transcripts/{transcriptId} {
      allow read: if isAuthenticated();
    }
    
    match /{path=**}/scorecards/{scorecardId} {
      allow read: if isAuthenticated();
    }
    
    match /{path=**}/tasks/{taskId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Leads and their subcollections
    match /leads/{leadId}/{document=**} {
      allow read, write: if isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role != 'Franchisee' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.franchisee == (
          exists(/databases/$(database)/documents/leads/$(leadId)) ? 
          get(/databases/$(database)/documents/leads/$(leadId)).data.franchisee : 
          null
        )
      );
    }

    // Companies and their subcollections
    match /companies/{companyId}/{document=**} {
      allow read, write: if isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role != 'Franchisee' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.franchisee == (
          exists(/databases/$(database)/documents/companies/$(companyId)) ? 
          get(/databases/$(database)/documents/companies/$(companyId)).data.franchisee : 
          null
        )
      );
    }

    // Visit Notes
    match /visitnotes/{noteId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAuthenticated() && (
        request.auth.uid == resource.data.capturedByUid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'Lead Gen Admin', 'Field Sales Admin'] ||
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Franchisee' && resource.data.franchisee == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.franchisee)
      );
    }

    // Upsells
    match /upsells/{upsellId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
    }

    // Daily Deployment Logs
    match /daily_area_logs/{logId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
    }

    // Team Schedules
    match /field_sales_schedules/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isFieldSalesAdmin();
    }
  }
}
