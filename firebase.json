{
  "apphosting": {
    "backendId": "studio",
    "rootDir": "./",
    "alwaysDeployFromSource": true
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json",
    "database": "(default)"
  },
  "functions": {
    "source": "functions",
    "predeploy": [
      "npm --prefix \"$RESOURCE_DIR\" run build"
    ],
    "ignore": [
      "node_modules",
      ".git",
      "firebase-debug.log",
      "firebase-debug.*.log",
      "*.local",
      "firebase-debug.log",
      "firebase-debug.*.log",
      ".runtimeconfig.json"
    ]
  }
}
